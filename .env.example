# =========================================================
# AIGC Marketing Platform - 环境变量模板
# 复制为 .env 后填入真实值。.env 不会被提交到 Git。
# =========================================================

# ---- 阿里云 DashScope（文案/策划/图片/视频均走此 Key）----
DASHSCOPE_API_KEY=

# ---- 文案 & 策划双模型（两步流程）----
# 初稿：DeepSeek-V4（数据驱动、结构清晰）
COPY_DRAFT_MODEL=deepseek-v4
# 润色：Qwen3.7-Max（专业中文表达优化）
COPY_POLISH_MODEL=qwen-plus

# ---- 海报图片生成 ----
POSTER_IMAGE_MODEL=qwen-image-2.0

# ---- 视频生成 ----
VIDEO_DEEPSEEK_MODEL=deepseek-v4
VIDEO_IMAGE_MODEL=qwen-image-2.0
VIDEO_CLIP_MODEL=wan2.7-14b-text2video

# ---- 其它可选模型（P2+ 升级时启用）----
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=

# ---- 数据库 ----
POSTGRES_USER=aigc
POSTGRES_PASSWORD=aigc_dev_pass
POSTGRES_DB=aigc
DATABASE_URL=postgresql+psycopg://aigc:aigc_dev_pass@localhost:5432/aigc

# ---- Redis（Celery + 缓存）----
REDIS_URL=redis://localhost:6379/0

# ---- Celery（异步任务队列）----
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_DEFAULT_QUEUE=aigc_default
CELERY_TASK_TRACK_STARTED=true

# ---- Qdrant（向量库，P2 起需要）----
QDRANT_URL=http://localhost:6333

# ---- MinIO（对象存储）----
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aigc

# ---- 安全 ----
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440

# ---- 内容安全（可选，留空则跳过）----
# ALIYUN_GREEN_AK=
# ALIYUN_GREEN_SK=
