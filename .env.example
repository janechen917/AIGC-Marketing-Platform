# =========================================================
# AIGC Marketing Platform - 环境变量模板
# 复制为 .env 后填入真实值。.env 不会被提交到 Git。
# =========================================================

# ---- 模型路由 ----
# 可选: github | qwen | deepseek | openai
LLM_PROVIDER=github

# ---- GitHub Models（P1 默认，免费）----
# 在 https://github.com/settings/tokens 创建一个 PAT（无需任何 scope）
GITHUB_TOKEN=
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com
GITHUB_MODELS_NAME=gpt-4o-mini

# ---- 阿里云 DashScope（P3 起需要：Qwen-Image-2.0 / Qwen-VL）----
DASHSCOPE_API_KEY=

# ---- 其它可选模型（P2+ 升级时启用）----
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=

# ---- 数据库 ----
POSTGRES_USER=aigc
POSTGRES_PASSWORD=aigc_dev_pass
POSTGRES_DB=aigc
DATABASE_URL=postgresql+psycopg://aigc:aigc_dev_pass@localhost:5432/aigc

# ---- Redis（Celery + 缓存）----
REDIS_URL=redis://localhost:6379/0

# ---- Qdrant（向量库，P2 起需要）----
QDRANT_URL=http://localhost:6333

# ---- MinIO（对象存储）----
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aigc

# ---- 安全 ----
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440

# ---- 内容安全（可选，留空则跳过）----
# ALIYUN_GREEN_AK=
# ALIYUN_GREEN_SK=
